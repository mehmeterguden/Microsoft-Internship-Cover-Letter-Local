# ════════════════════════════════════════════════════════════════
#  Cover Letter Local — .gitignore
#  Public repo. Internal working docs, secrets, runtime data, build
#  artifacts, and local dev conveniences stay local. Empty source
#  folders are kept with .gitkeep so the structure stays visible.
# ════════════════════════════════════════════════════════════════

# ─── Internal working docs — NOT published to GitHub ─────────────
#  (project brief for the AI, internal docs, Claude Code skills/config)
/CLAUDE.md
/docs/
/.claude/

# ─── Local dev conveniences (kept out of the public repo) ────────
# commit template — wired via local git config, not published
/.gitmessage
*.local.md

# ─── Secrets / environment ───────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
secrets.*

# ─── Runtime data — ChromaDB + SQLite, never commit ──────────────
data/
*.db
*.sqlite
*.sqlite3
*.sqlite3-journal

# ─── Generated exports (cover letters) ───────────────────────────
/exports/
*.docx
*.pdf

# ─── Graphify output (local code knowledge graph — dev tool) ──────
/graphify-out/

# ─── Local LLM / embedding model caches ──────────────────────────
/models/
*.gguf
*.safetensors
.cache/
.huggingface/

# ─── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.python-version

# ─── Node / Frontend ─────────────────────────────────────────────
node_modules/
.vite/
dist-ssr/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache

# ─── Logs ────────────────────────────────────────────────────────
*.log
logs/

# ─── Editor / IDE ────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.sublime-*

# ─── OS cruft ────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini
