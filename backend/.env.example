# Copy to .env and adjust. The .env file is gitignored.

# ── Storage (local files) ──
DATABASE_PATH=./data/cover_letter_local.db
CHROMA_PATH=./data/chroma

# ── CORS ──
FRONTEND_ORIGIN=http://localhost:5173

# ── Local LLM (OpenAI-compatible) — used in later phases ──
# Ollama:        http://localhost:11434/v1   (LLM_MODEL=phi3)
# Foundry Local: http://localhost:5273/v1    (LLM_MODEL=phi-4-mini)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=phi3

# ── Embeddings — used in later phases ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Company research (only external call) — used in later phases ──
TAVILY_API_KEY=
