# Copy to .env and adjust. The .env file is gitignored.

# ── Storage (local files) ──
DATABASE_PATH=./data/cover_letter_local.db
CHROMA_PATH=./data/chroma

# ── CORS ──
FRONTEND_ORIGIN=http://localhost:5173

# ── Local LLM — Microsoft Foundry Local (OpenAI-compatible) — used in later phases ──
LLM_BASE_URL=http://localhost:5273/v1
LLM_MODEL=phi-4-mini

# ── Embeddings — used in later phases ──
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Company research (only external call) — used in later phases ──
TAVILY_API_KEY=
